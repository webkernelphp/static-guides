{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "webkernel/static-guides",
    "description": "The Webkernel documentation and training-guides.",
    "version": "0.12.0",
    "type": "webkernel-assets",
    "license": "EPL-2.0",
    "require": {
        "php": ">=8.4",
        "webkernel/standard-lifecycle": "0.12.0"
    },
    "autoload": {
        "files": [],
        "psr-4": []
    },
    "extra": {
        "webkernel": {
            "package_repo": "git@github.com:webkernelphp/static-guides.git",
            "production": true,
            "prefix": "static"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
